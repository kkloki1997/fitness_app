{
  "name": "Loki Fitness",
  "short_name": "LokiFit",
  "description": "12-week body transformation tracker with AI coach, protein tracker, training plan, photo timelapse, Strava integration and progress charts.",
  "start_url": "./index.html",
  "id": "./index.html",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "tabbed", "standalone", "browser"],
  "orientation": "portrait-primary",
  "background_color": "#0D0D0D",
  "theme_color": "#E8621A",
  "scope": "./",
  "lang": "en-US",
  "dir": "ltr",
  "categories": ["health", "fitness", "lifestyle"],
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=io.github.kkloki1997.lokifit",
      "id": "io.github.kkloki1997.lokifit"
    }
  ],
  "icons": [
    { "src": "./icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "./icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "maskable" },
    { "src": "./icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "./icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ],
  "screenshots": [
    {
      "src": "./screenshot1.png",
      "sizes": "540x960",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Home screen with water tracker, streaks and daily log"
    },
    {
      "src": "./screenshot2.png",
      "sizes": "540x960",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Nutrition tracker with protein ring and food log"
    },
    {
      "src": "./screenshot-wide.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Dashboard view showing training, nutrition and progress"
    }
  ],
  "shortcuts": [
    {
      "name": "Log Today",
      "short_name": "Log",
      "url": "./index.html",
      "description": "Open daily training and nutrition log",
      "icons": [{ "src": "./icon-192.png", "sizes": "192x192" }]
    }
  ],
  "share_target": {
    "action": "./index.html",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "file_handlers": [
    {
      "action": "./index.html",
      "accept": {
        "image/*": [".jpg", ".jpeg", ".png", ".webp"]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+lokifit",
      "url": "./index.html?q=%s"
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "scope_extensions": [
    { "origin": "https://kkloki1997.github.io" }
  ],
  "handle_links": "preferred",
  "note_taking": {
    "new_note_url": "./index.html"
  },
  "tab_strip": {
    "home_tab": { "url": "./index.html" },
    "new_tab_button": { "url": "./index.html" }
  },
  "widgets": [
    {
      "name": "Loki Fitness Daily",
      "description": "Daily protein, water and training stats at a glance",
      "tag": "lokifit-daily",
      "ms_ac_template": "./widget-template.json",
      "data": "./widget-data.json",
      "type": "application/json",
      "screenshots": [
        { "src": "./screenshot1.png", "sizes": "540x960", "label": "Daily stats" }
      ],
      "icons": [
        { "src": "./icon-192.png", "sizes": "192x192" }
      ],
      "auth": false,
      "update": 86400
    }
  ]
}
